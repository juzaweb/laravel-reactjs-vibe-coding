{
    "name": "juzaweb/api",
    "description": "Api Module",
    "keywords": [
        "juzaweb",
        "api",
        "module",
        "laravel"
    ],
    "license": "GPL-2.0",
    "authors": [
        {
            "name": "Juzaweb CMS",
            "email": "admin@juzaweb.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "darkaonline/l5-swagger": "^8.6",
        "laravel/passport": "^13.0"
    },
    "require-dev": {
        "juzaweb/core": "^5.0",
        "laravel/pint": "dev-main",
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Juzaweb\\Modules\\Api\\": "src/",
            "Juzaweb\\Modules\\Api\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Juzaweb\\Modules\\Api\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Juzaweb\\Modules\\Api\\Providers\\ApiServiceProvider"
            ]
        }
    }
}
