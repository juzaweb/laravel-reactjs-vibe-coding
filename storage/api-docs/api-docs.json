        "/api/v1/settings": {
            "get": {
                "tags": [
                    "Settings"
                ],
                "summary": "Get site settings",
                "description": "Returns key-value pairs of public site settings such as title, logo, language, etc.",
                "operationId": "2ccbcdfc0219bfbf9ca6a734cdc41c51",
                "responses": {
                    "200": {
                        "description": "Successful operation",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "data": {
                                            "properties": {
                                                "title": {
                                                    "type": "string",
                                                    "example": "My Site"
                                                },
                                                "description": {
                                                    "type": "string",
                                                    "example": "Site description"
                                                },
                                                "sitename": {
                                                    "type": "string",
                                                    "example": "mysite"
                                                },
                                                "logo": {
                                                    "type": "string",
                                                    "example": "https://example.com/logo.png"
                                                },
                                                "favicon": {
                                                    "type": "string",
                                                    "example": "https://example.com/favicon.ico"
                                                },
                                                "banner": {
                                                    "type": "string",
                                                    "example": "https://example.com/banner.jpg"
                                                },
                                                "language": {
                                                    "type": "string",
                                                    "example": "en"
                                                },
                                                "captcha": {
                                                    "type": "string",
                                                    "example": "recaptcha"
                                                },
                                                "captcha_site_key": {
                                                    "type": "string",
                                                    "example": "site_key"
                                                },
                                                "languages": {
                                                    "description": "Available languages with code as key and name as value",
                                                    "type": "object",
                                                    "example": {
                                                        "en": "English",
                                                        "vi": "Vietnamese",
                                                        "ja": "Japanese"
                                                    },
                                                    "additionalProperties": {
                                                        "description": "Language name, e.g. English, Vietnamese, Japanese",
                                                        "type": "string"
                                                    }
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "500": {
                        "$ref": "#/components/responses/error_500"
                    }
                }
            }
        },
        "/api/v1/translations/{locale}": {
            "get": {
                "tags": [
                    "Translations"
                ],
                "summary": "Get i18n translation strings",
                "description": "Returns all translation key-value pairs for the given locale in i18n flat format (namespace::group.key => value).",
                "operationId": "5fa56809dd66e0a4a559a46687788f24",
                "parameters": [
                    {
                        "name": "locale",
                        "in": "path",
                        "description": "Locale code, e.g. en, vi, ja",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "example": "en"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Successful operation",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "data": {
                                            "description": "Flat key-value pairs: namespace::group.key => translated string",
                                            "type": "object",
                                            "example": {
                                                "core::app.save": "Save",
                                                "core::app.cancel": "Cancel"
                                            }
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "500": {
                        "$ref": "#/components/responses/error_500"
                    }
                }
            }
        }
    },
